# NeuroHUD — all optional. Copy to `.env` only if you need to change a default.
#
# There is no secret to fill in here. The access token is GENERATED on first run and stored in
# `state/token` (gitignored, mode 0600). You only set NEUROHUD_TOKEN below if you want to pin it
# yourself — for example, to keep one OBS browser-source URL working across machines.

# Port the relay listens on.
# NEUROHUD_PORT=8787

# Interface to bind. Loopback by default, and you almost certainly want to leave it that way:
# anything else puts a live biometric feed on your local network. The server prints a warning
# if you change it.
# NEUROHUD_HOST=127.0.0.1

# Pin the access token instead of using the generated one. Must be long and random —
# it is the only thing standing between a web page you have open and your live stream.
#   openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
# NEUROHUD_TOKEN=
