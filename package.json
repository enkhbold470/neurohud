{
	"name": "neurohud",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"description": "Your focus, live on stream. A dry-EEG headset as an OBS browser source — that refuses to show a number it can't defend.",
	"license": "MIT",
	"scripts": {
		"start": "bun run server.ts",
		"dev": "bun --hot server.ts",
		"sync:lib": "bun run scripts/sync-lib.ts",
		"check:lib": "bun run scripts/sync-lib.ts --check",
		"check": "tsc --noEmit",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"test": "bun run check:lib && bun run test:unit && bun run check && bun run test:e2e",
		"shoot": "bun run scripts/shoot.ts",
		"sim": "bun run scripts/simulate-headset.ts",
		"build": "bun run scripts/build-binaries.ts"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@types/bun": "^1.3.0",
		"@types/pngjs": "^6.0.5",
		"gifenc": "^1.0.3",
		"playwright": "^1.61.1",
		"pngjs": "^7.0.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	}
}
